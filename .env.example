# Authentication: configure ONE of these modes.
GOOGLE_API_KEY=replace_with_google_api_key

# Uncomment these if you prefer Vertex AI instead of GOOGLE_API_KEY.
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

PRODUCT_APP_NAME=product_app
PRODUCT_USER_ID=local_user
PRODUCT_SESSION_ID=local_session
PUBLIC_BASE_URL=https://PRODUCT_DOMAIN
APP_SESSION_SECRET=replace_with_long_random_secret

# App runtime controls.
RUN_RATE_LIMIT_WINDOW_SECONDS=300
RUN_RATE_LIMIT_MAX_REQUESTS=6
MAX_CONCURRENT_RUNS=2

# Local database fallback.
DATABASE_AUTO_CREATE=true
DATABASE_SQLITE_PATH=./product_app/app.db

# Preferred production database: Cloud SQL for PostgreSQL.
# DATABASE_URL can override everything below if you prefer a full Postgres DSN.
# DATABASE_URL=postgresql+pg8000://user:password@host:5432/product_app
CLOUD_SQL_INSTANCE_CONNECTION_NAME=test-agents-ai-app:us-central1:quien-prod
CLOUD_SQL_IP_TYPE=public
DATABASE_NAME=product_app
DATABASE_USER=svc_product_app
DATABASE_PASSWORD=
PRODUCT_DEFAULT_USER_EMAIL=owner@PRODUCT_DOMAIN
PRODUCT_DEFAULT_LANGUAGE=en
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5

PRODUCT_PREVIEW_MODEL=gemini-3-flash-preview
PRODUCT_COORDINATOR_MODEL=gemini-3-flash-preview
PRODUCT_SEARCH_MODEL=gemini-3.1-pro-preview
PRODUCT_REASONING_MODEL=gemini-3.1-pro-preview
PRODUCT_REPORT_MODEL=gemini-3-flash-preview
PRODUCT_ENABLE_INFOGRAPHIC=true
PRODUCT_OUTPUT_DIR=./product_app/outputs
PRODUCT_GCS_BUCKET=
PRODUCT_GCS_PREFIX=artifacts

# Tested 2026-03-13:
# - gemini-3.1-pro-preview worked for research and reasoning
# - gemini-3-flash-preview worked for coordination/tool-calling
# If ADK + google_search starts failing in your environment, fallback search to:
# PRODUCT_SEARCH_MODEL=gemini-2.5-pro

# Auth.
PRODUCT_ENABLE_DEV_AUTH=true
GOOGLE_OAUTH_AUDIENCE=

# Magic Link Auth
MAGIC_LINK_SECRET=change-me-to-a-random-secret
MAGIC_LINK_EXPIRY_MINUTES=15
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAGIC_LINK_FROM_EMAIL=noreply@PRODUCT_DOMAIN
# Factory email relay (auto-set by MVP Factory deploy; leave empty if using own SMTP)
FACTORY_EMAIL_API_URL=
FACTORY_EMAIL_API_KEY=

# Webhook
WEBHOOK_SIGNING_SECRET=change-me-to-a-random-secret
WEBHOOK_RETRY_MAX=3

# Admin
ADMIN_EMAIL=jean@sitiouno.com

# Product configuration.
WEBSITE_NAME=Product Name
WEBSITE_TAGLINE_EN=Deploy AI-powered MVPs in minutes.
WEBSITE_TAGLINE_ES=Despliega MVPs con IA en minutos.
COMPANY_LEGAL_NAME=Product Name
COMPANY_COUNTRY=US
SUPPORT_EMAIL=support@PRODUCT_DOMAIN
FULL_RUN_CREDIT_COST=1
API_KEY_DEFAULT_SCOPE=runs:read runs:write account:read
API_KEY_RATE_LIMIT_PER_MINUTE=60

# Open Registration
DEFAULT_INITIAL_CREDITS=10
EXTRA_BLOCKED_EMAIL_DOMAINS=

# Stripe Billing
STRIPE_SECRET_KEY_TEST=
STRIPE_SECRET_KEY_LIVE=
STRIPE_PUBLISHABLE_KEY_TEST=
STRIPE_PUBLISHABLE_KEY_LIVE=
STRIPE_WEBHOOK_SECRET_TEST=
STRIPE_WEBHOOK_SECRET_LIVE=
# Legacy fallback (used by bootstrap_stripe.py if _TEST not set):
# STRIPE_SECRET_KEY=

# GitHub Integration
GITHUB_TOKEN=ghp_your_token_here
GITHUB_ORG=sitiouno
TEMPLATE_REPO_OWNER=sitiouno
TEMPLATE_REPO_NAME=aaas-product-template
